Checks: >
  -*,
  bugprone-*,               # General bug-prone pattern checks
  readability-*,            # Readability rules
  misc-*,                   # Misc rules
  clang-analyzer-*,         # Static analysis
  performance-*,            # (optional) performance hints
  portability-*             # Cross-platform checks

CheckOptions:
  # ----- Typedef naming -----
  - key:             readability-identifier-naming.TypeAliasCase
    value:           lower_case
  - key:             readability-identifier-naming.TypeAliasSuffix
    value:           _t
  - key:             readability-identifier-naming.IgnoreMainLikeFunctions
    value:           1
  - key:             readability-identifier-naming.IgnoreMainLikeFunctions
    value:           true

  # ----- Require 'default' in switch -----
  - key:             bugprone-switch-missing-default.StrictMode
    value:           true
  - key:             bugprone-switch-missing-default.WarnOnAll
    value:           true

  # ----- Misc options -----
  - key:             readability-braces-around-statements.ShortStatementLines
    value:           0

WarningsAsErrors: ''
FormatStyle: file

